{
  "manifest_version": 3,
  "name": "Dark Pattern Sentinel",
  "version": "1.0",
  "description": "Detects dark patterns on websites",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://dark-pattern-sentinel.onrender.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
