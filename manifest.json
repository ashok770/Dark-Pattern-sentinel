{
  "manifest_version": 3,
  "name": "Dark Pattern Sentinel",
  "version": "1.0",
  "description": "Detects dark patterns on websites",

  "permissions": ["activeTab", "scripting"],

  "host_permissions": ["http://localhost:5000/*"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
